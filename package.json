{
  "name": "portfolio-militar-ti",
  "version": "1.0.0",
  "description": "Portfólio profissional para Militar da área de TI - Dark Terminal Theme",
  "main": "index.html",
  "scripts": {
    "start": "python -m http.server 8000",
    "serve": "npx http-server",
    "minify-css": "npx cssnano style.css -o style.min.css",
    "minify-js": "npx terser script.js -o script.min.js",
    "build": "npm run minify-css && npm run minify-js",
    "deploy": "git add . && git commit -m 'Update portfolio' && git push origin main"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seu-usuario/seu-usuario.github.io.git"
  },
  "keywords": [
    "portfolio",
    "militar",
    "ti",
    "infraestrutura",
    "cybersecurity",
    "terminal",
    "hacker",
    "github-pages"
  ],
  "author": "Seu Nome",
  "license": "MIT",
  "devDependencies": {
    "cssnano": "^5.1.13",
    "terser": "^5.16.0"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
